{
  "name": "editor-tests",
  "version": "1.0.0",
  "description": "Tests for MRPP Editor customizations",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "cd ../../../ && npx eslint@9 plugin/ -c three.js/editor/test/eslint.config.js",
    "lint:fix": "cd ../../../ && npx eslint@9 plugin/ -c three.js/editor/test/eslint.config.js --fix"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.6.0",
    "globals": "^14.0.0",
    "jsdom": "^23.0.0",
    "three": "^0.140.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
